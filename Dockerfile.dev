# Development Dockerfile — hot reload, test tooling included
FROM python:3.12-slim AS dev

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/*

COPY backend/requirements.txt .
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements.txt \
    && pip install --no-cache-dir watchfiles pytest-asyncio

# Source is volume-mounted in dev — don't COPY here
RUN mkdir -p /tmp/viralscan_uploads && chmod 700 /tmp/viralscan_uploads

EXPOSE 8000

# --reload watches for file changes
CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000", "--reload", "--log-level", "debug"]
